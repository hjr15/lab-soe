# Copy this file to ~/.config/lab-soe/secrets.env and fill in real values.
# bootstrap.sh sources it automatically (see load_secrets in scripts/lib.sh).
# Never commit the real file. Keep it at mode 0600.
#
#   mkdir -p ~/.config/lab-soe
#   cp secrets.env.example ~/.config/lab-soe/secrets.env
#   chmod 600 ~/.config/lab-soe/secrets.env
#
# None of the bundled installers currently require a secret. Add KEY=value
# lines here for any custom scripts/NN-*.sh you introduce that need one, e.g.:
#
#   EXAMPLE_API_TOKEN=replace_me
