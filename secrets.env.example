# Copy this file to ~/.config/lab-soe/secrets.env and fill in real values.
# Never commit the real file. Keep it at mode 0600.
#
#   mkdir -p ~/.config/lab-soe
#   cp secrets.env.example ~/.config/lab-soe/secrets.env
#   chmod 600 ~/.config/lab-soe/secrets.env

# GitHub Personal Access Token used by the GitHub MCP server in Claude Code.
# Scopes: depends on what you need Claude to do; minimum read access to your repos.
GITHUB_PAT=ghp_replace_me
